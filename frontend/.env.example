# =============================================================================
# IncidentIQ - environment configuration
#
# HOW TO USE:
#   1. Copy this file and rename the copy to ".env"  (no ".example" suffix)
#   2. Fill in ONE API key below (Anthropic or OpenAI)
#   3. Leave everything else as-is unless you know you need to change it
#
# The application also runs WITHOUT any API key, in OFFLINE mode. In that mode
# the deterministic analysis engine runs (evidence extraction, timeline, bias
# heuristics) and the UI clearly marks that no language model was consulted.
# =============================================================================


# --- Which provider to use ---------------------------------------------------
# anthropic | openai | offline
# "offline" forces the heuristic-only engine even if a key is present.
LLM_PROVIDER=anthropic


# --- Anthropic (Claude) ------------------------------------------------------
# Get a key at https://console.anthropic.com/  -> API Keys
ANTHROPIC_API_KEY=

# Model used for the main analysis pass.
#   claude-opus-4-8    - strongest reasoning (default)
#   claude-sonnet-5    - cheaper / faster, good enough for most incidents
#   claude-haiku-4-5   - cheapest, use only for smoke tests
ANTHROPIC_MODEL=claude-opus-4-8


# --- OpenAI (optional, used for the cross-model comparison experiment) -------
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o


# --- Analysis behaviour ------------------------------------------------------
# Upper bound on tokens the model may generate for one analysis.
MAX_OUTPUT_TOKENS=16000

# How many root-cause hypotheses to ask for (the brief requires "several").
HYPOTHESIS_COUNT=4

# Hard cap on how much raw input text is sent to the model, in characters.
# Protects against accidentally uploading a 50 MB log file.
MAX_INPUT_CHARS=120000

# Redact things that look like emails, IPs, tokens and card numbers before any
# text leaves this machine. Answers the brief's question "what information
# should not be sent to external AI APIs?".
REDACT_PII=true


# --- Local server ------------------------------------------------------------
HOST=127.0.0.1
PORT=8000

# Open the browser automatically when the one-click launcher starts.
AUTO_OPEN_BROWSER=true
